{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Global user state and progression metrics",
      "type": "object",
      "properties": {
        "xp": { "type": "number" },
        "lvl": { "type": "number" },
        "anaisXP": { "type": "number" },
        "soulResonance": { "type": "number" },
        "stoicEquilibrium": { "type": "number" },
        "poeticResonance": { "type": "number" },
        "subconsciousDepth": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["xp", "lvl"]
    },
    "Memory": {
      "title": "Archived Memory",
      "description": "Historical system recollections",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string" },
        "text": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["timestamp", "text"]
    },
    "Log": {
      "title": "System Log",
      "description": "Dynamic logs for the live data stream",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["SYS", "LOG", "WEB", "APP", "ERROR"] },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "content"]
    },
    "Artifact": {
      "title": "Inventory Artifact",
      "description": "Collected items and fragments",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["book", "key", "pen", "locked", "movies", "music", "books", "comics", "artists", "websites", "locations", "activities", "musician", "artist", "website"] },
        "name": { "type": "string" },
        "imageUrl": { "type": "string" },
        "collectedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type"]
    },
    "SyncEntry": {
      "title": "Sync Truth",
      "description": "Truths submitted to the Inner World matrix",
      "type": "object",
      "properties": {
        "truth": { "type": "string" },
        "imageUrl": { "type": "string" },
        "impact": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["truth"]
    },
    "SpatialAnchor": {
      "title": "Spatial Anchor",
      "description": "Places that ground the user in physical reality",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "coords": { "type": "string" },
        "impact": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "ExpeditionLog": {
      "title": "Expedition Log",
      "description": "Activities that define the user's external depth",
      "type": "object",
      "properties": {
        "activity": { "type": "string" },
        "resonance": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["activity"]
    },
    "NeuralBridge": {
      "title": "Neural Bridge",
      "description": "Links to the user's external digital presence for behavioral analysis",
      "type": "object",
      "properties": {
        "platform": { "type": "string" },
        "url": { "type": "string" },
        "resonance": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["platform", "url"]
    },
    "Recommendation": {
      "title": "Anaïs Recommendation",
      "description": "AI-suggested external resonance points (media, places, events)",
      "type": "object",
      "properties": {
        "category": { "type": "string", "enum": ["movie", "book", "comic", "website", "music", "place", "event"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "url": { "type": "string" },
        "resonanceScore": { "type": "number" },
        "isDismissed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["category", "title", "description"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Root user profile"
    },
    "/users/{userId}/memories/{memoryId}": {
      "schema": "Memory",
      "description": "Linked memories for the user"
    },
    "/users/{userId}/logs/{logId}": {
      "schema": "Log",
      "description": "Linked system logs"
    },
    "/users/{userId}/artifacts/{artifactId}": {
      "schema": "Artifact",
      "description": "Linked artifacts"
    },
    "/users/{userId}/sync_entries/{entryId}": {
      "schema": "SyncEntry",
      "description": "Linked sync entries"
    },
    "/users/{userId}/spatial_anchors/{anchorId}": {
      "schema": "SpatialAnchor",
      "description": "Places that ground the user"
    },
    "/users/{userId}/expedition_logs/{logId}": {
      "schema": "ExpeditionLog",
      "description": "User activities and their resonance"
    },
    "/users/{userId}/neural_bridges/{bridgeId}": {
      "schema": "NeuralBridge",
      "description": "External digital account links"
    },
    "/users/{userId}/recommendations/{recId}": {
      "schema": "Recommendation",
      "description": "AI suggestions for external discovery"
    }
  }
}
