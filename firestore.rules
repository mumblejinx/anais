rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isMumblejinx() {
      return isSignedIn() && 
             request.auth.token.email == 'mumblejinx@gmail.com' && 
             request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isMumblejinx() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidUserProfile(data) {
      return data.keys().hasAll(['xp', 'lvl']) && 
             data.keys().size() <= 10 &&
             data.xp is number && 
             data.lvl is number &&
             (data.soulResonance == null || data.soulResonance is number) &&
             (data.stoicEquilibrium == null || data.stoicEquilibrium is number);
    }

    function isValidMemory(data) {
      return data.keys().hasAll(['timestamp', 'text']) &&
             data.keys().size() <= 5 &&
             data.timestamp is string && data.timestamp.size() <= 10 &&
             data.text is string && data.text.size() <= 2000 &&
             data.createdAt == request.time;
    }

    function isValidLog(data) {
      return data.keys().hasAll(['type', 'content']) &&
             data.keys().size() <= 5 &&
             data.type in ['SYS', 'LOG', 'WEB', 'APP', 'ERROR'] &&
             data.content is string && data.content.size() <= 500 &&
             data.createdAt == request.time;
    }

    function isValidArtifact(data) {
      return data.keys().hasAll(['type']) &&
             data.type in ['book', 'key', 'pen', 'locked'] &&
             (data.name == null || (data.name is string && data.name.size() <= 100));
    }

    function isValidSyncEntry(data) {
      return data.keys().hasAll(['truth']) &&
             data.truth is string && data.truth.size() <= 5000 &&
             data.createdAt == request.time;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile(incoming());
      allow update: if isOwner(userId) && isValidUserProfile(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['xp', 'lvl', 'soulResonance', 'stoicEquilibrium', 'poeticResonance', 'subconsciousDepth', 'lastUpdated']);

      match /memories/{memoryId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId) && isValidId(memoryId);
        allow create: if isOwner(userId) && isValidMemory(incoming());
        allow delete: if isOwner(userId);
      }

      match /logs/{logId} {
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidLog(incoming());
      }

      match /artifacts/{artifactId} {
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidArtifact(incoming());
      }

      match /sync_entries/{entryId} {
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSyncEntry(incoming());
      }
    }
  }
}
